# Copiez ce fichier en .env.local et renseignez vos clés Supabase.
# (Project Settings → API dans le dashboard Supabase)

# URL publique du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Clé publique "anon" (sûre à exposer côté navigateur, protégée par RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon

# Clé "service_role" — SECRÈTE, utilisée uniquement côté serveur (votes, modération).
# Ne JAMAIS la préfixer NEXT_PUBLIC_ ni l'exposer au navigateur.
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role
